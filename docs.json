{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Filecheck",
  "colors": {
    "primary": "#F91B25",
    "light": "#FA4951",
    "dark": "#9D1217"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "index",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Core concepts",
            "pages": [
              "concepts/workflows",
              "concepts/jobs",
              "concepts/remediation",
              "concepts/soft-proofing"
            ]
          },
          {
            "group": "The Element",
            "pages": [
              "element/installation",
              "element/create-and-mount",
              "element/events",
              "element/presentation",
              "element/connectors"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/woocommerce",
              "integrations/shopify",
              "integrations/opencart-prestashop",
              "integrations/headless"
            ]
          },
          {
            "group": "Server-side",
            "pages": [
              "server/verify-jobs",
              "server/webhooks"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/status-payload",
              "reference/facts",
              "reference/errors",
              "reference/changelog"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "openapi": "openapi.json",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Jobs",
            "pages": [
              "POST /jobs",
              "GET /jobs",
              "GET /jobs/{id}",
              "DELETE /jobs/{id}",
              "POST /jobs/preflight",
              "POST /jobs/fix",
              "POST /jobs/optimize",
              "POST /jobs/validate",
              "POST /jobs/previews"
            ]
          },
          {
            "group": "Uploads & orders",
            "pages": [
              "POST /uploads",
              "POST /orders/{id}"
            ]
          },
          {
            "group": "Library",
            "pages": [
              "GET /workflows",
              "GET /workflows/{id}",
              "GET /connectors",
              "GET /connectors/{id}",
              "GET /rules",
              "GET /rules/{id}",
              "GET /profiles",
              "GET /profiles/{id}",
              "GET /optimize-presets",
              "GET /optimize-presets/{id}"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://filecheck.io",
          "icon": "globe"
        },
        {
          "anchor": "Demos",
          "href": "https://filecheck.io/demos",
          "icon": "play"
        },
        {
          "anchor": "Support",
          "href": "mailto:support@filecheck.io",
          "icon": "envelope"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://filecheck.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://admin.filecheck.io"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "download-spec",
      "chatgpt",
      "claude"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/filecheckio",
      "linkedin": "https://linkedin.com/company/filecheckio"
    }
  }
}
